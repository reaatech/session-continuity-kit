{
  "name": "@reaatech/session-continuity-tokenizers",
  "version": "0.1.0",
  "description": "Token counting utilities for session-continuity-kit",
  "type": "module",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "homepage": "https://github.com/reaatech/session-continuity-kit/tree/main/packages/tokenizers#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reaatech/session-continuity-kit.git",
    "directory": "packages/tokenizers"
  },
  "bugs": {
    "url": "https://github.com/reaatech/session-continuity-kit/issues"
  },
  "keywords": [
    "session-continuity-kit",
    "tokenizer",
    "tiktoken",
    "anthropic",
    "openai",
    "llm"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "type-check": "tsc --noEmit --project tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dqbd/tiktoken": "^1.0.22"
  },
  "peerDependencies": {
    "@reaatech/session-continuity": "workspace:*",
    "@anthropic-ai/tokenizer": "^0.0.1"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/tokenizer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@reaatech/session-continuity": "workspace:*",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
