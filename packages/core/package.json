{
  "name": "@session-continuity-kit/core",
  "version": "0.1.0",
  "description": "Core abstractions and session management for session-continuity-kit",
  "type": "module",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "homepage": "https://github.com/reaatech/session-continuity-kit/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reaatech/session-continuity-kit.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/reaatech/session-continuity-kit/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "session",
    "conversation",
    "token-budget",
    "compression"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
