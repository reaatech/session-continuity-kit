{
  "name": "@session-continuity-kit/storage-memory",
  "version": "0.1.0",
  "description": "In-memory storage adapter for session-continuity-kit",
  "type": "module",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "homepage": "https://github.com/reaatech/session-continuity-kit/tree/main/packages/storage-memory#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reaatech/session-continuity-kit.git",
    "directory": "packages/storage-memory"
  },
  "bugs": {
    "url": "https://github.com/reaatech/session-continuity-kit/issues"
  },
  "keywords": [
    "session-continuity-kit",
    "storage-adapter",
    "in-memory",
    "testing"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@session-continuity-kit/core": "workspace:*"
  },
  "devDependencies": {
    "@session-continuity-kit/core": "workspace:*",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
